# ============================================================
# Super-Agent Platform - Configuration
# ============================================================

# Port for the backend server
PORT=3001

# AI Provider: "mock" | "claude" | "openai" | "ollama"
# Use "mock" to test without an API key
AI_PROVIDER=mock

# --- Claude (Anthropic) ---
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Ollama (local, free) ---
# Install: https://ollama.com | Start: ollama serve | Pull: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Data directory (relative to backend/)
DATA_DIR=./data

# CORS allowed origin for frontend
FRONTEND_URL=http://localhost:3000

# Maximum concurrent agent executions (default: 3)
# Increase for faster parallel workflows, decrease to limit resource usage
MAX_CONCURRENT_EXECUTIONS=3

# --- Authentication (Phase 3) ---
# Optional static API key – leave empty to disable auth (default for local dev)
# When set: all /api/* routes require "Authorization: Bearer <value>" header
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# --- Webhook notifications (Phase 3) ---
# Called via POST when an execution completes (success or error)
# WEBHOOK_URL=https://hooks.example.com/superagent
# Optional shared secret sent in X-Webhook-Secret header
# WEBHOOK_SECRET=

# --- Scheduler (Phase 4A) ---
# Interval in ms between schedule checks (default: 60000 = 1 minute)
SCHEDULER_INTERVAL_MS=60000

# --- Memory / RAG (Phase 4B) ---
# Enable automatic memory indexation and context injection (default: false)
MEMORY_ENABLED=false

# --- Memory embeddings / RAG hybrid (Phase 4D) ---
# OFF by default: keyword search remains the fallback and default behavior.
MEMORY_EMBEDDINGS=false
MEMORY_EMBEDDING_PROVIDER=ollama
MEMORY_EMBEDDING_MODEL=nomic-embed-text
MEMORY_EMBEDDING_DIMENSIONS=
MEMORY_HYBRID_ALPHA=0.65
MEMORY_REINDEX_BATCH_SIZE=20
MEMORY_EMBEDDING_TIMEOUT_MS=15000

# --- Memory evaluation / cleanup (Phase 4E) ---
# Local RAG evaluation uses backend/data/memory/eval-queries.json.
# Reports are written to backend/data/memory/evaluation-reports/.
# No extra provider is required; vector mode is marked unavailable when embeddings are off.

# --- Storage JSON / SQLite (Phase 5) ---
# Default stays JSON for compatibility. SQLite can be enabled after migration validation.
STORAGE_MODE=json
SQLITE_DB_PATH=backend/data/super-agent-platform.sqlite
SQLITE_ENABLE_WAL=true
SQLITE_DOUBLE_WRITE=false
SQLITE_READ_PREFERENCE=json
SQLITE_MIGRATION_BACKUP=true
BACKUP_INCLUDE_SQLITE_DB=false
BACKUP_INCLUDE_SQLITE_DUMP=true

# --- Storage admin / Migration Control (Phase 5B) ---
STORAGE_ADMIN_ENABLED=true
STORAGE_ADMIN_ALLOW_MUTATIONS=false
STORAGE_ADMIN_REQUIRE_CONFIRMATION=true
STORAGE_CHECKSUM_SAMPLE_SIZE=100
STORAGE_SYNC_HISTORY_LIMIT=100

# --- Auth enhancements (Phase 6F) ---
# JTI blacklist store: "auto" (SQLite if available, else memory), "memory", "sqlite"
ACCESS_BLACKLIST_STORE=auto
# Interval for blacklist entry cleanup (ms) — 6 hours default
ACCESS_BLACKLIST_CLEANUP_INTERVAL_MS=21600000
# Interval for session/JTI/audit cleanup (ms) — 6 hours default
AUTH_CLEANUP_INTERVAL_MS=21600000
# Enable automatic cleanup on server start (disabled by default)
AUTH_CLEANUP_ENABLED=false
# Include auth.sqlite in backup (false by default — keep auth data separate)
BACKUP_INCLUDE_AUTH_DB=false
# Include auth summary (counts only, no secrets) in backup
BACKUP_INCLUDE_AUTH_SUMMARY=true
# Capture client IP in audit log
AUDIT_CAPTURE_IP=true
# Capture User-Agent in audit log
AUDIT_CAPTURE_USER_AGENT=true

# --- Phase 7: Observability & Admin Reports ---
# Rate limit for POST /api/auth/sessions/revoke-all (per user)
REVOKE_ALL_RATE_LIMIT_WINDOW_MS=900000
REVOKE_ALL_RATE_LIMIT_MAX=5
