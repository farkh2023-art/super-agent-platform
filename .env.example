# ============================================================
# Super-Agent Platform - Configuration
# ============================================================

# Port for the backend server
PORT=3001

# AI Provider: "mock" | "claude" | "openai" | "ollama"
AI_PROVIDER=mock

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Data directory (relative to backend/)
DATA_DIR=./data

# CORS allowed origin for frontend
FRONTEND_URL=http://localhost:3000
