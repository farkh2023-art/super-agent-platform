# ============================================================
# Super-Agent Platform – .gitignore
# ============================================================

# ── Secrets & configuration sensible ────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx

# ── Données runtime (générées automatiquement) ───────────────
backend/data/
data/
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db
backend/data/*.sqlite
backend/data/*.sqlite-shm
backend/data/*.sqlite-wal
backend/data/db/*.sqlite
backend/data/db/*.sqlite-shm
backend/data/db/*.sqlite-wal

# ── Dépendances Node.js ──────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
.npm
.yarn-integrity

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Données de test temporaires ──────────────────────────────
backend/data-test/
backend/migration-backups/
coverage/
.nyc_output/

# ── OS / IDE ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.suo
*.user

# ── Build artefacts ───────────────────────────────────────────
dist/
build/
*.tgz
