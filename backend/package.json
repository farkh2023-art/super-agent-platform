{
  "name": "super-agent-platform-backend",
  "version": "1.0.0",
  "description": "Super-Agent Platform Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/ --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.56.0",
    "pdfkit": "^0.15.0",
    "better-sqlite3": "^12.9.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
