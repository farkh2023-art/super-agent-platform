# Super-Agent Platform local configuration template
# Copy to .env and edit locally. Do not commit .env.

PORT=3001
AI_PROVIDER=mock
AUTH_MODE=single
STORAGE_MODE=json
DATA_DIR=./data
FRONTEND_URL=http://localhost:3000
MAX_CONCURRENT_EXECUTIONS=3

# Optional providers. Leave empty in demo mode.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Security defaults for local use.
API_KEY=
JWT_SECRET=change-this-before-multi-user-mode
REFRESH_TOKEN_TRANSPORT=cookie
CSRF_PROTECTION=false

# Storage and backup.
SQLITE_DB_PATH=backend/data/super-agent-platform.sqlite
BACKUP_INCLUDE_SQLITE_DB=false
BACKUP_INCLUDE_AUTH_DB=false
BACKUP_INCLUDE_AUTH_SUMMARY=true
